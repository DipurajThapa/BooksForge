{{!--
  cargo-about template for BooksForge.

  Run from booksforge/ root:

      cargo install --locked cargo-about
      cargo about init                       # only on first run
      cargo about generate \
          --output-file ../THIRD_PARTY_LICENSES.rust.html \
          about.hbs

  Output is a self-contained HTML file with the license + attribution
  for every Rust crate compiled into the binary, suitable for
  bundling into the installer.

  Refs: EXTERNAL_AUDIT_BACKLOG.md #4, THIRD_PARTY_LICENSES.md.
--}}<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>BooksForge — Third-Party Rust Licenses</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; max-width: 64rem; margin: 2rem auto; padding: 0 1rem; line-height: 1.5; color: #1f2328; }
  h1 { font-size: 1.5rem; }
  h2 { font-size: 1.1rem; margin-top: 2rem; padding-bottom: 0.25rem; border-bottom: 1px solid #d0d7de; }
  h3 { font-size: 1rem; margin-top: 1.5rem; }
  ul { padding-left: 1.5rem; }
  pre { background: #f6f8fa; padding: 0.75rem; border-radius: 0.375rem; overflow-x: auto; font-size: 0.85rem; }
  code { background: #f6f8fa; padding: 0.1rem 0.3rem; border-radius: 0.25rem; font-size: 0.9em; }
  .license-summary { margin: 1rem 0 2rem; }
  .crate-list { columns: 2; column-gap: 2rem; }
</style>
</head>
<body>
<h1>BooksForge — Third-Party Rust Licenses</h1>
<p>
  This document lists the open-source Rust crates compiled into
  BooksForge and their respective licenses, generated automatically
  from <code>Cargo.lock</code> via <code>cargo-about</code>.
  Bundled fonts, sidecar binaries (Pandoc, EPUBCheck), and npm
  dependencies are listed separately in
  <a href="THIRD_PARTY_LICENSES.md"><code>THIRD_PARTY_LICENSES.md</code></a>.
</p>

<h2>License summary</h2>
<div class="license-summary">
<ul>
{{#each overview}}
  <li><strong>{{name}}</strong> — used by {{count}} crate{{#unless (eq count 1)}}s{{/unless}}</li>
{{/each}}
</ul>
</div>

{{#each licenses}}
<h2>{{name}}</h2>
<p>The following crate{{#unless (eq used_by.length 1)}}s use{{else}} uses{{/unless}} the {{name}} license:</p>
<ul class="crate-list">
{{#each used_by}}
  <li>
    <a href="{{this.crate.repository}}"><code>{{this.crate.name}} {{this.crate.version}}</code></a>
    {{#if this.crate.authors}} — {{this.crate.authors}}{{/if}}
  </li>
{{/each}}
</ul>
<details>
<summary>License text</summary>
<pre>{{text}}</pre>
</details>
{{/each}}

<hr>
<p><small>
  Generated {{now}} from
  <code>booksforge/Cargo.lock</code>.
  See <a href="https://github.com/DipurajThapa/BooksForge/blob/main/THIRD_PARTY_LICENSES.md"><code>THIRD_PARTY_LICENSES.md</code></a>
  for the canonical attribution registry.
</small></p>
</body>
</html>
