{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "ESNext",
    "moduleResolution": "Bundler",
    "strict":           true,
    "noEmit":           true,
    "skipLibCheck":     true,
    "esModuleInterop":  true,
    "resolveJsonModule": true,
    "types":            ["@playwright/test", "node"]
  },
  "include": ["src/**/*.ts", "playwright.config.ts"]
}
