{
  "name": "booksforge",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev":       "pnpm --filter @booksforge/desktop-ui tauri dev",
    "build":     "pnpm --filter @booksforge/desktop-ui tauri build",
    "typecheck": "pnpm -r typecheck",
    "lint":      "pnpm -r lint",
    "test":      "pnpm -r test"
  }
}
