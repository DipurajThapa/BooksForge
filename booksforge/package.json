{
  "name": "booksforge",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev":             "pnpm --filter @booksforge/desktop-ui tauri dev",
    "build":           "pnpm --filter @booksforge/desktop-ui tauri build",
    "typecheck":       "pnpm -r typecheck",
    "lint":            "pnpm -r lint",
    "test":            "pnpm -r --filter='!@booksforge/visual-regression' test",
    "gen:fixtures":    "cargo run -p booksforge-export-epub --example visual_fixtures",
    "visual:test":     "pnpm gen:fixtures && pnpm --filter @booksforge/visual-regression test",
    "visual:update":   "pnpm gen:fixtures && pnpm --filter @booksforge/visual-regression update-golden"
  }
}
