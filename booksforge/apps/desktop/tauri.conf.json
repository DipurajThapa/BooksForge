{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BooksForge",
  "version": "0.0.1",
  "identifier": "com.booksforge.app",
  "build": {
    "beforeDevCommand": "pnpm -C src-ui dev",
    "beforeBuildCommand": "pnpm -C src-ui build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../apps/desktop/src-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "BooksForge",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:11434"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/pandoc-3.5"
    ]
  }
}
