{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capability set for BooksForge.",
  "platforms": ["macOS", "windows"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:window:default",
    "core:app:default",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
